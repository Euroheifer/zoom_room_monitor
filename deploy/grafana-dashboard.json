        "targets": [ { "refId": "A", "datasource": { "type": "alexanderzobnin-zabbix-datasource", "uid": "zabbix-poc" }, "queryType": "5", "group": { "filter": "Rooms/Singapore" }, "host": { "filter": "/.*/" }, "application": { "filter": "" }, "trigger": { "filter": "" }, "options": { "minSeverity": 0, "sortProblems": "default", "acknowledged": 2 } } ],
        "options": { "hostField": "hostname", "statusField": false, "severityField": true, "hostTechNameField": false, "showTags": true, "hostGroups": false, "sortProblemsField": "lastchange", "ackEventColor": false, "pageSize": 20, "fontSize": "100%", "highlightNewerThan": "1h" }
      },
      {
        "id": 7, "type": "stat", "title": "Room status grid (red = offline)",
        "gridPos": { "x": 0, "y": 13, "w": 24, "h": 11 },
        "datasource": { "type": "alexanderzobnin-zabbix-datasource", "uid": "zabbix-poc" },
        "targets": [ { "refId": "A", "datasource": { "type": "alexanderzobnin-zabbix-datasource", "uid": "zabbix-poc" }, "queryType": "0", "group": { "filter": "Rooms/Singapore" }, "host": { "filter": "/.*/" }, "application": { "filter": "" }, "item": { "filter": "Room online (1/0)" }, "functions": [], "options": {} } ],
        "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "name", "justifyMode": "auto", "wideLayout": true },
        "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "displayName": "${__field.labels.host}", "mappings": [ { "type": "value", "options": { "0": { "text": "OFFLINE", "color": "red" }, "1": { "text": "OK", "color": "green" } } } ], "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "red" }, { "value": 1, "color": "green" } ] } }, "overrides": [] }
      }
