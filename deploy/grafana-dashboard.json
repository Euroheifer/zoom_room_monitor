{
  "overwrite": true,
  "folderId": 0,
  "dashboard": {
    "uid": "zoom-sg-poc",
    "title": "Zoom Rooms — Singapore (POC)",
    "tags": ["zoom", "poc"],
    "timezone": "browser",
    "schemaVersion": 39,
    "refresh": "30s",
    "time": { "from": "now-6h", "to": "now" },
    "templating": { "list": [] },
    "panels": [
      {
        "id": 1, "type": "stat", "title": "Total Rooms",
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "datasource": { "type": "alexanderzobnin-zabbix-datasource", "uid": "zabbix-poc" },
        "targets": [ { "refId": "A", "datasource": { "type": "alexanderzobnin-zabbix-datasource", "uid": "zabbix-poc" }, "queryType": "0", "group": { "filter": "Rooms/Singapore" }, "host": { "filter": "SG Fleet Summary" }, "application": { "filter": "" }, "item": { "filter": "Fleet: total rooms" }, "functions": [], "options": {} } ],
        "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "value" },
        "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] }
      },
      {
        "id": 2, "type": "stat", "title": "Online",
        "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
        "datasource": { "type": "alexanderzobnin-zabbix-datasource", "uid": "zabbix-poc" },
        "targets": [ { "refId": "A", "datasource": { "type": "alexanderzobnin-zabbix-datasource", "uid": "zabbix-poc" }, "queryType": "0", "group": { "filter": "Rooms/Singapore" }, "host": { "filter": "SG Fleet Summary" }, "application": { "filter": "" }, "item": { "filter": "Fleet: rooms online" }, "functions": [], "options": {} } ],
        "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "value" },
        "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] }
      },
      {
        "id": 3, "type": "stat", "title": "Offline now",
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
        "datasource": { "type": "alexanderzobnin-zabbix-datasource", "uid": "zabbix-poc" },
        "targets": [ { "refId": "A", "datasource": { "type": "alexanderzobnin-zabbix-datasource", "uid": "zabbix-poc" }, "queryType": "0", "group": { "filter": "Rooms/Singapore" }, "host": { "filter": "SG Fleet Summary" }, "application": { "filter": "" }, "item": { "filter": "Fleet: rooms offline" }, "functions": [], "options": {} } ],
        "options": { "reduceOptions": { "calcs": ["lastNotNull"], "values": false }, "colorMode": "background", "graphMode": "area", "textMode": "value" },
        "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "value": null, "color": "green" }, { "value": 1, "color": "red" } ] } }, "overrides": [] }
      },
      {
        "id": 4, "type": "stat", "title": "In Meeting",
        "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
        "datasource": { "type": "alexanderzobnin-zabbix-datasource", "uid": "zabbix-poc" },
